# Mimo API 配置
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL_ID=mimo-v2.5-pro

# 视觉模型（可选，为空则跳过图片识别）
OPENAI_MULTIMODAL_MODEL=

# 服务配置
UPLOAD_DIR=data/uploads
OUTPUT_DIR=data/output_reports
RULES_CONFIG_PATH=config/rules_config.json
LOG_DIR=logs
MAX_WORKERS=3
